# Credentials — never track these, encrypted or not
.authinfo
.authinfo*
!.authinfo.gpg
*.authinfo.bak

# Byte-compiled Elisp — regenerated automatically, never worth tracking
*.elc

# Backup and autosave files
*~
\#*\#
.\#*
*.bak

# undo-tree persistence files
*.~undo-tree~

# Emacs / Prelude caches
.cache/
elpa/
auto-save-list/
tramp
url/
eshell/history
eshell/lastdir

# OS cruft
.DS_Store

# Themes/packages installed by direct git clone — not versioned here,
# fetch from their own upstream repo if needed
themes/emacs-leuven-theme/
